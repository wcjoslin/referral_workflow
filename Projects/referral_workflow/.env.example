# ── Mock Direct Gateway (IMAP / SMTP) ────────────────────────────────────────
# Recommended: Mailtrap (https://mailtrap.io) sandbox — free tier is sufficient.
# Create an inbox, then copy the SMTP and IMAP credentials here.

IMAP_HOST=sandbox.imap.mailtrap.io
IMAP_PORT=993
IMAP_USER=your_mailtrap_username
IMAP_PASSWORD=your_mailtrap_password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=10000

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password

# The Direct address of this receiving system (used in MDN Final-Recipient)
RECEIVING_DIRECT_ADDRESS=receiving@specialist.direct

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=./referral.db

# ── Google Gemini API (used in PRD-02 and PRD-04) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
