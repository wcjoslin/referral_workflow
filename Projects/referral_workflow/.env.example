# ── Inbound (IMAP) ────────────────────────────────────────────────────────────
# Gmail: enable IMAP in settings, then generate an App Password at
# myaccount.google.com → Security → 2-Step Verification → App passwords

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_gmail_address
IMAP_PASSWORD=your_gmail_app_password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=10000

# ── Outbound (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address
SMTP_PASSWORD=your_gmail_app_password

# The Direct address of this receiving system (used in MDN Final-Recipient)
RECEIVING_DIRECT_ADDRESS=receiving@specialist.direct

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=./referral.db

# ── Google Gemini API (used in PRD-02 and PRD-04) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── FHIR Client (PRD-08 patient enrichment) ──────────────────────────────────
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# ── Skills / Rules Engine (PRD-09) ────────────────────────────────────────────
SKILLS_DIR=./skills
SKILL_OVERRIDE_WINDOW_HOURS=24
PENDING_INFO_TIMEOUT_HOURS=72
PENDING_INFO_CHECK_INTERVAL_MS=3600000

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
